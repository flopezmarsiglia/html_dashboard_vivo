# Cadena de conexión a Postgres (Supabase, Neon, o cualquier Postgres compatible).
# En Supabase: Project Settings -> Database -> Connection string -> "Transaction pooler".
DATABASE_URL=postgres://usuario:password@host:6543/postgres?sslmode=require

# Credenciales para acceder a /admin (panel de respuestas) y /api/export.
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-clave

# Nombre de la concesionaria, se muestra en el formulario (opcional).
# Si se deja vacío o sin definir, el formulario queda neutral (sin nombrar ninguna concesionaria).
NEXT_PUBLIC_DEALERSHIP_NAME=
